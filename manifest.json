{
  "manifest_version": 3,
  "name": "Clawd Mochi — Claude Limits",
  "version": "0.1.0",
  "description": "See your Claude session (5h) and weekly usage at a glance — and optionally show it on a tiny desk crab over USB.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["alarms", "storage"],
  "host_permissions": [
    "https://claude.ai/*",
    "http://127.0.0.1/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Clawd Mochi Limits",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
